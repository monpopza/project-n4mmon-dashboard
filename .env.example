# n4mmon-dashboard — Environment Variables
# Copy to .env and fill in values. Never commit .env to version control.

# ─── Firebase Auth (project monpopza-3ed44) ──────────────────────────────────
# All values available in Firebase Console → Project Settings → Your Apps → Web app
VITE_FIREBASE_API_KEY=your-firebase-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=monpopza-3ed44.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=monpopza-3ed44

# ─── Service API URLs ─────────────────────────────────────────────────────────
# Base URL of each backend service. No trailing slash.
VITE_SHORTLINK_API_URL=http://localhost:3000
VITE_POLYMARKET_API_URL=http://localhost:3001
VITE_TRADE_API_URL=http://localhost:8081
VITE_ANDROID_BOT_API_URL=http://localhost:8080

# ─── Auth tokens ─────────────────────────────────────────────────────────────
# shortlink-web admin token (Authorization: Bearer <token>)
VITE_SHORTLINK_ADMIN_TOKEN=your-shortlink-admin-token-here

# android-bot API key (X-API-Key: <key>)
VITE_ANDROID_BOT_API_KEY=your-android-bot-api-key-here
